{
  "name": "resume-news-mcp",
  "version": "1.0.0",
  "description": "MCP server para resumen diario de noticias desde múltiples fuentes RSS",
  "main": "dist/main.js",
  "type": "module",
  "bin": {
    "resume-news-mcp": "dist/main.js"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "tsx main.ts",
    "build": "tsc",
    "dev": "tsx watch main.ts",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": ["mcp", "news", "rss", "model-context-protocol", "claude"],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.30.3",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "rss-parser": "^3.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
